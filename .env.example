# Copy to .env and fill in. .env is gitignored.
OPENAI_API_KEY=sk-...

# Required only for ingesting the knowledge base (scripts/ingest_kb.py).
# Free tier at firecrawl.dev — ~500 credits/mo is plenty for ~30 URLs.
FIRECRAWL_API_KEY=fc-...

# Optional — Qdrant URL. Default works with the docker-compose service.
# QDRANT_URL=http://localhost:6333
